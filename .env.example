# Copy this file to .env and fill in the keys for the features you want.
# Nothing here has a real value — the app runs with zero keys set (you just
# get the bundled Nixon demo persona over text chat, no video/phone).

PORT=3000

# Only matters if you're hosting one shared public demo on your own keys
# (see README "Free hosting") — per-IP requests allowed per minute.
RATE_LIMIT_PER_MIN=12
AVATAR_RATE_LIMIT_PER_MIN=3
SPEAK_RATE_LIMIT_PER_MIN=12

# Which persona to run. "nixon" ships in this repo and works with no setup.
# Set to "me" (or any folder name under personas/) once you've built your own —
# see personas/me.example/README.md.
PERSONA=nixon

# ── Brain (required for any chat at all) ───────────────────────────────────
# Google AI Studio → https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── Video avatar (Tavus) — optional ────────────────────────────────────────
# https://platform.tavus.io — free tier is 25 conversation minutes/month.
TAVUS_API_KEY=
# Created once via `npm run build-profile` or the Tavus dashboard; a stock
# face works fine to start (see README "Tavus setup").
TAVUS_FACE_ID=

# ── Voice (ElevenLabs) — optional, powers /talk (voice chat) and phone calls
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# A persona can suggest its own voiceId (see personas/nixon/persona.json) —
# only set this to override it, e.g. because you don't have access to the
# original creator's cloned voice and made/picked your own instead.
ELEVENLABS_VOICE_ID=

# ── Phone number (Twilio) — optional ────────────────────────────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Public base URL Twilio can reach (e.g. your Railway/ngrok URL). Required
# only for voice calls, which serve generated audio back to Twilio.
PUBLIC_URL=
